generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" for production
  url      = env("DATABASE_URL")
}

// ─── USERS (Customers) ─────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatar    String?
  address   String?
  city      String   @default("Pattaya")
  lat       Float?
  lng       Float?
  role      String   @default("customer") // customer | admin
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  reviews   Review[]
  addresses Address[]
  payments  Payment[]
}

// ─── PARTNERS (Service Providers) ───────────────────
model Partner {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  bio           String?
  idNumber      String?
  experience    Int      @default(0) // years
  isVerified    Boolean  @default(false)
  isOnline      Boolean  @default(false)
  isActive      Boolean  @default(true)
  rating        Float    @default(0)
  totalJobs     Int      @default(0)
  totalEarnings Float    @default(0)
  bankName      String?
  bankAccount   String?
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categories    PartnerCategory[]
  serviceAreas  PartnerServiceArea[]
  schedules     PartnerSchedule[]
  bookings      Booking[]
  reviews       Review[]
  earnings      Earning[]
  documents     Document[]
}

// ─── SERVICE CATEGORIES ─────────────────────────────
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  nameTh    String?  // Thai name
  icon      String
  image     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  services  Service[]
  partners  PartnerCategory[]
}

// ─── SERVICES ───────────────────────────────────────
model Service {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  nameTh      String?
  description String?
  icon        String?
  price       Float    // Base price in THB
  duration    String   // e.g. "1-2h"
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category  @relation(fields: [categoryId], references: [id])
  bookings    Booking[]
}

// ─── PARTNER ↔ CATEGORY (Many-to-Many) ──────────────
model PartnerCategory {
  id         String   @id @default(cuid())
  partnerId  String
  categoryId String
  createdAt  DateTime @default(now())

  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([partnerId, categoryId])
}

// ─── PARTNER SERVICE AREAS ──────────────────────────
model PartnerServiceArea {
  id        String  @id @default(cuid())
  partnerId String
  area      String  // e.g. "Central Pattaya", "Jomtien"

  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, area])
}

// ─── PARTNER SCHEDULE ───────────────────────────────
model PartnerSchedule {
  id        String  @id @default(cuid())
  partnerId String
  day       String  // Mon, Tue, Wed, Thu, Fri, Sat, Sun
  isActive  Boolean @default(true)
  startTime String? // "09:00"
  endTime   String? // "18:00"

  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, day])
}

// ─── BOOKINGS ───────────────────────────────────────
model Booking {
  id          String   @id @default(cuid())
  bookingNo   String   @unique // BK-20260408-001
  userId      String
  partnerId   String?
  serviceId   String
  status      String   @default("pending") // pending | confirmed | in_progress | completed | cancelled
  date        DateTime
  timeSlot    String   // "10:00 AM"
  address     String
  city        String   @default("Pattaya")
  lat         Float?
  lng         Float?
  notes       String?
  price       Float
  platformFee Float    @default(49)
  totalAmount Float
  paymentStatus String @default("unpaid") // unpaid | paid | refunded
  cancelReason  String?
  completedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  partner     Partner? @relation(fields: [partnerId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
  review      Review?
  payment     Payment?
}

// ─── REVIEWS ────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  partnerId String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  partner   Partner  @relation(fields: [partnerId], references: [id])
}

// ─── PAYMENTS ───────────────────────────────────────
model Payment {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  userId        String
  amount        Float
  method        String   // cash | card | transfer | promptpay
  status        String   @default("pending") // pending | completed | failed | refunded
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

// ─── PARTNER EARNINGS ───────────────────────────────
model Earning {
  id        String   @id @default(cuid())
  partnerId String
  amount    Float
  type      String   // job | bonus | withdrawal
  status    String   @default("pending") // pending | paid | withdrawn
  note      String?
  date      DateTime @default(now())

  partner   Partner  @relation(fields: [partnerId], references: [id])
}

// ─── PARTNER DOCUMENTS ──────────────────────────────
model Document {
  id        String   @id @default(cuid())
  partnerId String
  type      String   // id_card | certificate | photo | other
  url       String
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())

  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// ─── USER ADDRESSES ─────────────────────────────────
model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   // Home, Office, etc.
  address   String
  city      String   @default("Pattaya")
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
